{
  "name": "wxrank-mcp",
  "version": "1.0.0",
  "description": "MCP server for wxrank WeChat public account data APIs",
  "keywords": [
    "mcp",
    "typescript",
    "wechat",
    "wxrank",
    "zod"
  ],
  "license": "MIT",
  "author": "",
  "bin": {
    "wxrank-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "smoke": "bash scripts/smoke.sh",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src --deny-warnings",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "check": "pnpm run format && pnpm run lint && pnpm run typecheck"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
